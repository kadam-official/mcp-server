# Kadam MCP Server Configuration
# At least one API key must be provided.

# Advertiser API key (partners.kadam.net -> Profile -> API)
# Enables: campaigns, creatives, audiences, finances, advertiser stats
KADAM_ADV_API_KEY=

# Publisher API key (pub.kadam.net -> Profile -> API)
# Enables: sites, ad units, publisher stats
KADAM_PUB_API_KEY=

# Optional: API base URLs (defaults shown)
# KADAM_ADV_API_BASE=https://partners.kadam.net/api/v1
# KADAM_PUB_API_BASE=https://pub.kadam.net/api

# Optional: Log level (default: info)
# LOG_LEVEL=debug
